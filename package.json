{
	"name": "@remunda/backstage-plugins",
	"version": "0.1.0",
	"private": true,
	"description": "Mono-repo for Backstage DataContract plugins (frontend and backend).",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/remunda/backstage-plugins.git"
	},
	"license": "Apache-2.0",
	"bugs": {
		"url": "https://github.com/remunda/backstage-plugins/issues"
	},
	"homepage": "https://github.com/remunda/backstage-plugins",
	"scripts": {
		"start:be": "yarn workspace @remunda/backstage-plugin-datacontract-backend start",
		"start:fe": "yarn workspace @remunda/backstage-plugin-datacontract start",
		"build:be": "yarn workspace @remunda/backstage-plugin-datacontract-backend build",
		"build:fe": "yarn workspace @remunda/backstage-plugin-datacontract build",
		"build": "yarn tsc && yarn build:be && yarn build:fe",
		"start": "concurrently \"yarn start:be\" \"yarn start:fe\"",
		"local-publish": "yarn build && yarn workspaces foreach --all --no-private exec \"rimraf local-publish && mkdir -p local-publish && npm pack --pack-destination=local-publish\"",
		"precommit": "yarn biome check --fix && yarn biome lint --write && yarn biome format --fix && yarn tsc && yarn test",
		"prepare": "husky",
		"changeset": "changeset",
		"changeset:version": "changeset version",
		"changeset:publish": "changeset publish",
		"release": "yarn build && yarn changeset:publish",
		"test": "yarn workspaces foreach --all --no-private run test"
	},
	"workspaces": [
		"plugins/*"
	],
	"packageManager": "yarn@4.9.2",
	"devDependencies": {
		"@backstage/cli": "^0.33.1",
		"@biomejs/biome": "^2.1.2",
		"@changesets/changelog-github": "^0.5.1",
		"@changesets/cli": "^2.29.6",
		"concurrently": "^9.2.0",
		"husky": "^9.1.7",
		"rimraf": "^6.0.1",
		"typescript": "~5.8.0"
	},
	"resolutions": {
		"@types/react": "^18",
		"@types/react-dom": "^18"
	},
	"engines": {
		"node": "20 || 22"
	}
}
