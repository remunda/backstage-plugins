{
  "compilerOptions": {
    "declaration": true,
    "module": "ESNext",
    "target": "es2019",
    "outDir": "dist",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "types": [
      "react",
      "node"
    ],
    "moduleResolution": "node"
  },
  "include": [
    "src"
  ]
}
