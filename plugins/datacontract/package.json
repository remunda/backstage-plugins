{
	"name": "@remunda/backstage-plugin-datacontract",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"publishConfig": {
		"access": "public",
		"main": "dist/index.esm.js",
		"types": "dist/index.d.ts"
	},
	"backstage": {
		"role": "frontend-plugin",
		"pluginId": "backstage-plugin-datacontract",
		"pluginPackages": [
			"@remunda/backstage-plugin-datacontract"
		]
	},
	"sideEffects": false,
	"scripts": {
		"start": "backstage-cli package start",
		"build": "yarn datacontract:update-templates && backstage-cli package build",
		"lint": "backstage-cli package lint",
		"test": "backstage-cli package test",
		"clean": "backstage-cli package clean",
		"prepack": "backstage-cli package prepack",
		"postpack": "backstage-cli package postpack",
		"datacontract:update-templates": "node scripts/update-templates.js && yarn datacontract:precompile-templates",
		"datacontract:precompile-templates": "yarn nunjucks-precompile templates > src/templates/templates.generated.js"
	},
	"dependencies": {
		"@backstage/core-components": "0.17.4",
		"@backstage/core-plugin-api": "1.10.9",
		"@backstage/plugin-api-docs": "^0.12.9",
		"@backstage/theme": "0.6.7",
		"@material-ui/core": "^4.9.13",
		"@material-ui/icons": "4.11.3",
		"@material-ui/lab": "^4.0.0-alpha.61",
		"js-yaml": "^4.1.0",
		"nunjucks": "^3.2.4",
		"react-use": "^17.2.4"
	},
	"peerDependencies": {
		"react": "^16.13.1 || ^17.0.0 || ^18.0.0"
	},
	"devDependencies": {
		"@backstage/cli": "0.33.1",
		"@backstage/core-app-api": "1.18.0",
		"@backstage/dev-utils": "1.1.12",
		"@backstage/test-utils": "1.7.10",
		"@testing-library/dom": "^10.4.0",
		"@testing-library/jest-dom": "6.6.3",
		"@testing-library/react": "16.3.0",
		"@testing-library/user-event": "14.6.1",
		"@types/js-yaml": "^4.0.9",
		"@types/nunjucks": "^3.2.6",
		"@types/react": "^19.1.9",
		"@types/react-dom": "^19",
		"msw": "2.10.4",
		"react": "^18.0.2",
		"react-dom": "^18.0.2",
		"react-router": "^6.3.0",
		"react-router-dom": "^6.3.0",
		"typescript": "^5.9.2"
	},
	"files": [
		"dist"
	]
}
